# copy this to .env and fill in real values
# .env is git-ignored, never commit real credentials

# postgres connection string (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://whispers:whispers_dev_password@localhost:5432/whispers_app

# ssl is auto-detected from the DATABASE_URL hostname (off for localhost, on
# otherwise). only set this if that guess is wrong -- e.g. a non-localhost
# hostname that's still plaintext postgres, like a docker-compose service name
# DATABASE_SSL=true

# port express listens on
PORT=5000

# comma separated list of origins allowed to hit the api
CORS_ORIGIN=http://localhost:5173

# max upload size in mb for audio/video clips
MAX_UPLOAD_MB=100
